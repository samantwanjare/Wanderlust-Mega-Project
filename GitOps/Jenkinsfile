pipeline {
    agent { label 'Node' }

    environment {
        AWS_ACCOUNT_ID = '769265543964'
        AWS_REGION = 'ap-south-1'

        BACKEND_REPO = 'wanderlust-backend'
        FRONTEND_REPO = 'wanderlust-frontend'

        GIT_REPO = 'https://github.com/samantwanjare/Wanderlust-Mega-Project.git'
        GIT_BRANCH = 'main'
    }

    parameters {
        string(name: 'BACKEND_DOCKER_TAG', defaultValue: 'v1', description: 'Backend Docker Tag')
        string(name: 'FRONTEND_DOCKER_TAG', defaultValue: 'v1', description: 'Frontend Docker Tag')
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Repository') {
            steps {
                git branch: "${GIT_BRANCH}",
                    credentialsId: 'Github-cred',
                    url: "${GIT_REPO}"
            }
        }

        stage('Verify Parameters') {
            steps {
                sh '''
                echo "Backend Tag  : ${BACKEND_DOCKER_TAG}"
                echo "Frontend Tag : ${FRONTEND_DOCKER_TAG}"
                '''
            }
        }

        stage('Update Kubernetes Manifests') {
            steps {
                dir('kubernetes') {
                    sh """
                    sed -i 's|image:.*wanderlust-backend:.*|image: ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${BACKEND_REPO}:${BACKEND_DOCKER_TAG}|' backend.yaml

                    sed -i 's|image:.*wanderlust-frontend:.*|image: ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${FRONTEND_REPO}:${FRONTEND_DOCKER_TAG}|' frontend.yaml

                    echo "===== Updated Images ====="
                    grep image backend.yaml
                    grep image frontend.yaml
                    """
                }
            }
        }

        stage('Git Commit') {
            steps {
                sh '''
                git config --global user.name "Jenkins"
                git config --global user.email "jenkins@local"

                git add .

                git commit -m "Deploy Backend ${BACKEND_DOCKER_TAG} Frontend ${FRONTEND_DOCKER_TAG}" || true
                '''
            }
        }

        stage('Push Changes') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'Github-cred',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {

                    sh '''
                    git remote set-url origin https://${GIT_USER}:${GIT_TOKEN}@github.com/samantwanjare/Wanderlust-Mega-Project.git
                    git push origin main
                    '''
                }
            }
        }

        stage('ArgoCD Deployment') {
            steps {
                echo "Git updated successfully."
                echo "ArgoCD Auto Sync will deploy the latest images."
            }
        }
    }

    post {

        success {
            echo "====================================="
            echo "CD Pipeline Completed Successfully"
            echo "====================================="
        }

        failure {
            echo "====================================="
            echo "CD Pipeline Failed"
            echo "====================================="
        }
    }
}
